// ============== Types ============== //

export type {{modelName}}Model = z.infer<typeof {{modelName}}Schema>;

export type {{modelName}}Relations = z.infer<typeof {{modelName}}IncludeSchema>;

export type {{modelName}}Complete = z.infer<typeof {{modelName}}Schema> & z.infer<typeof {{modelName}}IncludeSchema>;

export type {{modelName}}Count = number;

// ============== Schema Types ============== //

const create{{modelName}}Schema: ZodType<Prisma.{{modelName}}CreateArgs> = z.strictObject({
    data: {{modelName}}CreateInputSchema,
});

const update{{modelName}}Schema: ZodType<Prisma.{{modelName}}UpdateArgs> = z.strictObject({
    where: {{modelName}}WhereUniqueInputSchema,
    data: {{modelName}}UpdateInputSchema,
});

const delete{{modelName}}Schema: ZodType<Prisma.{{modelName}}DeleteArgs> = z.strictObject({
    where: {{modelName}}WhereUniqueInputSchema,
});

const select{{modelName}}Schema: ZodType<Prisma.{{modelName}}FindUniqueArgs> = z.strictObject({
    where: {{modelName}}WhereUniqueInputSchema,
});

const selectMany{{modelName}}Schema: ZodType<Prisma.{{modelName}}FindManyArgs> = z.strictObject({
    where: {{modelName}}WhereInputSchema,
});

const count{{modelName}}Schema: ZodType<Prisma.{{modelName}}CountArgs> = z.strictObject({
    where: {{modelName}}WhereInputSchema,
});

// ============== CRUD Props Types ============== //

export type Create{{modelName}}Props = z.infer<typeof create{{modelName}}Schema>;

export type Update{{modelName}}Props = z.infer<typeof update{{modelName}}Schema>;

export type Delete{{modelName}}Props = z.infer<typeof delete{{modelName}}Schema>;

export type FindUnique{{modelName}}Props = z.infer<typeof select{{modelName}}Schema>;

export type FindMany{{modelName}}Props = z.infer<typeof selectMany{{modelName}}Schema>;

export type Count{{modelName}}Props = z.infer<typeof count{{modelName}}Schema>;

// ============== CRUD Response Types ============== //

export type ResponseFormat<Key extends string, Response> = { [key in Key]: Response } | { error: string };

export type Create{{modelName}}Response = ResponseFormat<"{{modelNameLower}}", {{modelName}}Model>;

export type Update{{modelName}}Response = ResponseFormat<"{{modelNameLower}}", {{modelName}}Model>;

export type Delete{{modelName}}Response = ResponseFormat<"{{modelNameLower}}", {{modelName}}Model>;

export type FindUnique{{modelName}}Response = ResponseFormat<"{{modelNameLower}}", {{modelName}}Complete | null>;

export type FindMany{{modelName}}Response = ResponseFormat<"{{modelNameLower}}List", {{modelName}}Complete[]>;

export type Count{{modelName}}Response = ResponseFormat<"{{modelNameLower}}Amount", {{modelName}}Count>;

